directed_grassmann_distance <- function(QA, QC) {
# QA: orthonormal basis of A (n x p)
# QC: orthonormal basis of C (n x r), r <= p
# projection onto orthogonal complement of C
QAc <- (diag(nrow(QA)) - QC %*% t(QC)) %*% QA
s <- svd(QAc, nu = 0, nv = 0)$d
s[s<1e-10] <- 0.0
theta <- asin(pmin(s, 1))
sqrt(sum(theta^2))
}
directed_grassmann_distance(QA, QC)
directed_grassmann_distance(QA, QC)/pi
