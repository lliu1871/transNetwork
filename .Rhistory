grassmann_distance <- function(A, B) {
# Orthonormalize columns
QA <- qr.Q(qr(A))
QB <- qr.Q(qr(B))
# Compute principal angles via SVD of A^T B
M <- t(QA) %*% QB
s <- svd(M)$d
s[s > 1] <- 1  # numerical correction
# Principal angles
theta <- acos(s)
# Grassmann (geodesic) distance
sqrt(sum(theta^2))
}
grassmann_distance(QB, QA)
directed_grassmann_distance(QA, QC)
directed_grassmann_distance(QA, QC)/pi
