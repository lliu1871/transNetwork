norm_vector<-function(x){
sqrt(sum(x^2))
}
project_vector <- function(x, A){
proj <- A%*%solve(t(A)%*%A)%*%t(A)
proj%*%x
}
angle_vectors <- function(x,y){
a <- (x/norm_vector(x))%*%(y/norm_vector(y))
acos(a)
}
